{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "backend:run",
			"type": "shell",
			"command": ".\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"uvicorn",
				"backend.api.main:app",
				"--host",
				"127.0.0.1",
				"--port",
				"8000"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "backend:smoke-test",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/smoke-test.ps1"
			],
			"isBackground": false,
			"problemMatcher": []
		}
	]
}